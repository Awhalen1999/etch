{
  "name": "@etch/cli",
  "version": "0.0.1",
  "description": "etch — a text horror game in your terminal.",
  "type": "module",
  "bin": {
    "etch": "./dist/etch"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bun build --compile --minify --target=bun src/index.tsx --outfile=dist/etch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
